# ═══════════════════════════════════════════════
# PrintFarm Manager — Configuration
# ═══════════════════════════════════════════════
# Copia este archivo como .env y editá las IPs
# de tus impresoras antes de ejecutar install.sh
# ═══════════════════════════════════════════════

# Las impresoras ahora se configuran directamente desde la interfaz web.

# ─── Spoolman ─────────────────────────────────
# URL interna (dentro de Docker network)
SPOOLMAN_URL=http://spoolman:8000

# ─── Base de Datos ────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/printfarm.db

# ─── Mantenimiento (umbrales en horas) ───────
DEFAULT_NOZZLE_THRESHOLD=200
DEFAULT_BELT_THRESHOLD=500
DEFAULT_LUBRICATION_THRESHOLD=300

# ─── CORS ─────────────────────────────────────
CORS_ORIGINS=*

# ─── WebSocket / Monitor ─────────────────────
WS_RECONNECT_INTERVAL=5
MONITOR_POLL_INTERVAL=30

# ─── G-codes ──────────────────────────────────
GCODES_PATH=/app/gcodes

# ─── Telegram ─────────────────────────────────
# Las notificaciones de Telegram se configuran
# desde la interfaz web (Configuración > Telegram).
# No se requieren variables de entorno.
