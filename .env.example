# ═══════════════════════════════════════════════
# PrintFarm Manager — Configuration
# ═══════════════════════════════════════════════
# Copia este archivo como .env y editá las IPs
# de tus impresoras antes de ejecutar install.sh
# ═══════════════════════════════════════════════

# ─── Impresoras ───────────────────────────────
# Configuración JSON de las impresoras.
# Nota: El Sonic Pad usa 1 IP con puertos distintos
# para cada impresora (7125, 7126, 7127, 7128).
#
# Editá las IPs según tu red local:
PRINTERS_CONFIG='[
  {"name": "Ender3-01", "model": "Ender 3 V2 Neo", "url": "http://192.168.1.100:7125", "nozzle": 0.4},
  {"name": "Ender3-02", "model": "Ender 3 V2 Neo", "url": "http://192.168.1.100:7126", "nozzle": 0.4},
  {"name": "Ender3-03", "model": "Ender 3 V2 Neo", "url": "http://192.168.1.100:7127", "nozzle": 0.4},
  {"name": "Ender3-04", "model": "Ender 3 V2 Neo", "url": "http://192.168.1.100:7128", "nozzle": 0.4},
  {"name": "Neptune4Max", "model": "Elegoo Neptune 4 Max", "url": "http://192.168.1.105:7125", "nozzle": 0.4},
  {"name": "Trimaker", "model": "Trimaker", "url": "http://192.168.1.106:7125", "nozzle": 0.4}
]'

# ─── Spoolman ─────────────────────────────────
# URL interna (dentro de Docker network)
SPOOLMAN_URL=http://spoolman:8000

# ─── Base de Datos ────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/printfarm.db

# ─── Mantenimiento (umbrales en horas) ───────
DEFAULT_NOZZLE_THRESHOLD=200
DEFAULT_BELT_THRESHOLD=500
DEFAULT_LUBRICATION_THRESHOLD=300

# ─── CORS ─────────────────────────────────────
CORS_ORIGINS=*

# ─── WebSocket / Monitor ─────────────────────
WS_RECONNECT_INTERVAL=5
MONITOR_POLL_INTERVAL=30

# ─── G-codes ──────────────────────────────────
GCODES_PATH=/app/gcodes
